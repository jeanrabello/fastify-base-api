{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node 22",
  "_version": "22.0.0",

  "compilerOptions": {
    "lib": ["es2023", "DOM"],
    "module": "node16",
    "target": "es2022",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "paths": {
      "@config/*": ["./src/config/*"],
      "@lang/*": ["./src/lang/*"],
      "@middlewares/*": ["./src/shared/middlewares/*"],
      "@plugins/*": ["./src/plugins/*"],
      "@modules/*": ["./src/modules/*"],
      "@utils/*": ["./src/shared/utils/*"],
      "@src/*": ["./src/*"]
    }
  }
}
