{
  "name": "fastify-base-api",
  "version": "1.0.0",
  "description": "Projeto base para criação de APIs",
  "main": "index.js",
  "engines": {
    "node": "22.12.0"
  },
  "scripts": {
    "start": "node ./dist/server.js",
    "dev": "tsx watch --inspect=9229 ./src/server.ts",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage --coverageReporters=html",
    "compose:dev": "docker compose -f compose.dev.yml up -d --build",
    "build": "tsc && tsc-alias"
  },
  "keywords": [],
  "author": "Jean Rabello",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "10.0.1",
    "@fastify/swagger": "9.4.0",
    "@fastify/swagger-ui": "5.2.0",
    "bcrypt": "6.0.0",
    "dotenv": "16.4.7",
    "fastify": "5.2.0",
    "fastify-type-provider-zod": "4.0.2",
    "mongodb": "6.12.0",
    "nodemailer": "6.10.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.6",
    "@types/bcrypt": "6.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "22.10.3",
    "@types/nodemailer": "6.4.17",
    "cross-env": "7.0.3",
    "eslint": "9.30.1",
    "jest": "30.0.4",
    "prettier": "3.4.2",
    "ts-jest": "29.4.0",
    "tsc-alias": "1.8.10",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
